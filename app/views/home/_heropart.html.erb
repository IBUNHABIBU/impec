<!-- Hero Section -->
<div class="relative h-screen w-full overflow-hidden">
  <!-- Background Image Slider -->
  <% if hero.images.attached? %>
    <div class="absolute inset-0 w-full h-full">
      <%= render 'home/slider', obj: hero %>
    </div>
  <% else %>
    <div class="absolute inset-0 w-full h-full bg-gradient-to-br from-[#A53F2B] to-[#8A351F] flex items-center justify-center">
      <h1 class="text-white text-2xl">No images to display</h1>
    </div>
  <% end %>

  <!-- Dark Overlay for Text Readability - Make sure it doesn't block clicks -->
  <div class="absolute inset-0 bg-black/40 z-10 pointer-events-none"></div>
  
  <!-- Gradient Overlay for Smooth Transition - Make sure it doesn't block clicks -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-black/30 z-10 pointer-events-none"></div>

  <!-- Foreground Content - This should NOT block clicks to the arrows -->
  <div class="absolute inset-0 z-20 flex items-center justify-center pointer-events-none">
    <div class="container mx-auto px-4 text-center text-white pointer-events-none">
      <div class="max-w-4xl mx-auto pointer-events-none">
        <!-- Animated Badge - Make text selectable but not block clicks -->
        <div class="inline-block mb-6 animate-fade-in-up pointer-events-none">
          <span class="bg-[#FFB347]/20 backdrop-blur-sm text-[#FFB347] px-4 py-2 rounded-full text-sm font-medium tracking-wider border border-[#FFB347]/30 pointer-events-none">
            Welcome to Impeccable Africa
          </span>
        </div>
        
        <!-- Main Heading - Text only, shouldn't block clicks -->
        <h1 class="mb-6 animate-fade-in-up animation-delay-200 pointer-events-none">
          <span class="block text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold mb-2 drop-shadow-lg pointer-events-none">
            <%= hero.title %>
          </span>
          <span class="block text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-light text-[#FFB347] drop-shadow-lg pointer-events-none">
            <%= hero.subtitle %>
          </span>
        </h1>

        <!-- Description - Text only, shouldn't block clicks -->
        <p class="text-lg md:text-xl lg:text-2xl mb-10 max-w-3xl mx-auto text-white/90 drop-shadow-lg animate-fade-in-up animation-delay-400 pointer-events-none">
          <%= hero.description %>
        </p>

        <!-- CTA Buttons - These SHOULD be clickable -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-up animation-delay-600 pointer-events-auto">
          <%= link_to "#featured-tours", class: "group bg-[#FFB347] text-[#2D2418] px-8 py-4 rounded-lg font-semibold text-lg hover:bg-[#E3B23C] transition-all duration-300 transform hover:scale-105 shadow-xl hover:shadow-2xl inline-flex items-center justify-center gap-2 cursor-pointer" do %>
            <span>Explore Tours</span>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          <% end %>
          
          <%= link_to gallery_path, 
              class: "group bg-transparent text-white px-8 py-4 rounded-lg font-semibold text-lg border-2 border-white/50 hover:border-white hover:bg-white/10 transition-all duration-300 transform hover:scale-105 backdrop-blur-sm inline-flex items-center justify-center gap-2 cursor-pointer" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <span>View Gallery</span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Scrolling Indicator - Clickable -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-30 animate-bounce pointer-events-auto">
    <a href="#featured-tours" class="block w-10 h-10 bg-white/10 backdrop-blur-sm rounded-full border border-white/30 flex items-center justify-center hover:bg-white/20 transition-colors duration-300 group cursor-pointer">
      <svg class="w-5 h-5 text-white group-hover:text-[#FFB347] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </a>
  </div>
</div>