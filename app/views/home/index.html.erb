<!-- Home Page -->
<% if @hero %>
  <!-- Hero Section -->
  <%= render 'home/heropart', hero: @hero %>
<% else %>
  <!-- Empty State -->
  <div class="min-h-[60vh] flex items-center justify-center bg-gradient-to-b from-amber-50 to-white">
    <div class="text-center max-w-md mx-auto px-4">
      <div class="w-24 h-24 bg-[#A53F2B]/10 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-12 h-12 text-[#A53F2B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
      </div>
      <h2 class="text-3xl font-bold text-gray-900 mb-4">No hero section configured</h2>
      <p class="text-gray-600 mb-8">Get started by creating your travel hero section</p>
      <% if user_signed_in? %>
        <%= link_to "Create Hero Section", new_hero_path, 
            class: "inline-flex items-center gap-2 bg-[#A53F2B] text-white px-6 py-3 rounded-lg hover:bg-[#8A351F] transition-colors duration-300 font-medium" %>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Featured Tours Section -->
<section id="featured-tours" class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      <span class="text-[#A53F2B] font-semibold text-sm uppercase tracking-wider">Discover</span>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">
        <span class="block">Our Featured Adventures</span>
        <span class="text-[#A53F2B]">Handpicked Experiences</span>
      </h2>
      <p class="text-gray-600 text-lg">
        Discover our most popular tours loved by travelers worldwide
      </p>
    </div>

    <% if @featured_tours.any? %>
      <!-- Tour Cards Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @featured_tours.each do |tour| %>
          <div class="group bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
            <!-- Tour Image -->
            <div class="relative h-64 overflow-hidden">
              <% if tour.image.attached? %>
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10"></div>
                <%= image_tag tour.image.variant(resize_to_limit: [600, 400]), 
                    loading: "lazy", 
                    alt: tour.name,
                    class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" %>
              <% else %>
                <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                  <span class="text-gray-400">No image available</span>
                </div>
              <% end %>
              
              <!-- Category Badge -->
              <div class="absolute top-4 left-4 z-20">
                <span class="bg-[#FFB347] text-[#2D2418] px-3 py-1 rounded-full text-xs font-semibold">
                  <%= tour.category %>
                </span>
              </div>
              
              <!-- Duration Badge -->
              <div class="absolute top-4 right-4 z-20">
                <span class="bg-white/90 backdrop-blur-sm text-gray-700 px-3 py-1 rounded-full text-xs font-semibold flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <%= tour.duration %> days
                </span>
              </div>
            </div>

            <!-- Tour Content -->
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-[#A53F2B] transition-colors">
                <%= tour.name %>
              </h3>

              <p class="text-gray-600 mb-4 line-clamp-2">
                <%= truncate(tour.description, length: 100) %>
              </p>

              <!-- Price and CTA -->
              <div class="flex items-center justify-between">
                <div>
                  <span class="text-sm text-gray-500">From</span>
                  <span class="text-2xl font-bold text-[#A53F2B]">$<%= tour.price %></span>
                </div>
                
                <%= link_to travel_tour_path(tour), 
                    class: "inline-flex items-center gap-2 bg-[#FFB347] text-[#2D2418] px-4 py-2 rounded-lg hover:bg-[#E3B23C] transition-colors duration-300 font-medium group" do %>
                  <span>View Tour</span>
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- View All Link -->
      <div class="text-center mt-12">
        <%= link_to travel_tours_path, 
            class: "inline-flex items-center gap-2 text-[#A53F2B] font-semibold hover:text-[#8A351F] transition-colors duration-300 group" do %>
          <span>View All Tours</span>
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        <% end %>
      </div>

    <% else %>
      <!-- Empty State -->
      <div class="text-center py-16 bg-amber-50 rounded-2xl">
        <div class="w-20 h-20 bg-[#A53F2B]/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-10 h-10 text-[#A53F2B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
        </div>
        <p class="text-gray-600 mb-4">No featured tours available yet</p>
        <% if user_signed_in? %>
          <%= link_to "Create a Tour", new_travel_tour_path, 
              class: "inline-flex items-center gap-2 bg-[#A53F2B] text-white px-6 py-3 rounded-lg hover:bg-[#8A351F] transition-colors duration-300 font-medium" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<!-- Why Travel With Us -->
<section class="py-20 bg-amber-50">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      <span class="text-[#A53F2B] font-semibold text-sm uppercase tracking-wider">Why Choose Us</span>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">Why Travel With Us?</h2>
      <p class="text-gray-600 text-lg">We're committed to making your adventure unforgettable</p>
    </div>

    <!-- Features Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Expert Guides -->
      <div class="bg-white p-6 rounded-xl text-center hover:shadow-xl transition-shadow duration-300 group">
        <div class="w-16 h-16 bg-[#A53F2B]/10 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-[#A53F2B] transition-colors duration-300">
          <svg class="w-8 h-8 text-[#A53F2B] group-hover:text-white transition-colors duration-300" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Expert Guides</h3>
        <p class="text-gray-600">Our local guides have unmatched knowledge of each destination.</p>
      </div>

      <!-- Small Groups -->
      <div class="bg-white p-6 rounded-xl text-center hover:shadow-xl transition-shadow duration-300 group">
        <div class="w-16 h-16 bg-[#A53F2B]/10 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-[#A53F2B] transition-colors duration-300">
          <svg class="w-8 h-8 text-[#A53F2B] group-hover:text-white transition-colors duration-300" fill="currentColor" viewBox="0 0 20 20">
            <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Small Groups</h3>
        <p class="text-gray-600">Intimate groups for a more personal experience.</p>
      </div>

      <!-- Unique Locations -->
      <div class="bg-white p-6 rounded-xl text-center hover:shadow-xl transition-shadow duration-300 group">
        <div class="w-16 h-16 bg-[#A53F2B]/10 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-[#A53F2B] transition-colors duration-300">
          <svg class="w-8 h-8 text-[#A53F2B] group-hover:text-white transition-colors duration-300" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Unique Locations</h3>
        <p class="text-gray-600">Access to hidden gems beyond typical tourist routes.</p>
      </div>

      <!-- Easy Booking -->
      <div class="bg-white p-6 rounded-xl text-center hover:shadow-xl transition-shadow duration-300 group">
        <div class="w-16 h-16 bg-[#A53F2B]/10 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-[#A53F2B] transition-colors duration-300">
          <svg class="w-8 h-8 text-[#A53F2B] group-hover:text-white transition-colors duration-300" fill="currentColor" viewBox="0 0 20 20">
            <path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z"/>
            <path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Easy Booking</h3>
        <p class="text-gray-600">Simple online reservation with flexible options.</p>
      </div>
    </div>
  </div>
</section>

<!-- Destinations Section -->
<section id="destinations" class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      <span class="text-[#A53F2B] font-semibold text-sm uppercase tracking-wider">Explore</span>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">Explore Our Top Destinations</h2>
      <p class="text-gray-600 text-lg">From majestic mountains to pristine beaches</p>
    </div>

    <% if @popular_destinations.any? %>
      <!-- Destinations Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @popular_destinations.each do |destination| %>
          <div class="group relative h-80 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300">
            <!-- Destination Image -->
            <% if destination.image.attached? %>
              <%= image_tag destination.image.variant(resize_to_limit: [600, 400]), 
                  loading: "lazy", 
                  alt: destination.name,
                  class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" %>
            <% else %>
              <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                <span class="text-gray-400">No image available</span>
              </div>
            <% end %>

            <!-- Gradient Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>

            <!-- Content -->
            <div class="absolute bottom-0 left-0 right-0 p-6 text-white transform translate-y-0 group-hover:translate-y-[-4px] transition-transform duration-300">
              <h3 class="text-2xl font-bold mb-1"><%= destination.name %></h3>
              <p class="text-white/80 mb-3 flex items-center gap-1">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
                <%= destination.country %>
              </p>
              <%= link_to destination_path(destination), 
                  class: "inline-flex items-center gap-2 text-[#FFB347] hover:text-white transition-colors duration-300 group/link" do %>
                <span>View destination</span>
                <svg class="w-4 h-4 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-16 bg-amber-50 rounded-2xl">
        <div class="w-20 h-20 bg-[#A53F2B]/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-10 h-10 text-[#A53F2B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
        </div>
        <p class="text-gray-600 mb-4">No featured destinations available yet</p>
        <% if user_signed_in? %>
          <%= link_to "Add Destinations", new_destination_path, 
              class: "inline-flex items-center gap-2 bg-[#A53F2B] text-white px-6 py-3 rounded-lg hover:bg-[#8A351F] transition-colors duration-300 font-medium" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<!-- Testimonials Section -->
<section class="py-20 bg-amber-50">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      <span class="text-[#A53F2B] font-semibold text-sm uppercase tracking-wider">Stories</span>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">Traveler Stories</h2>
      <p class="text-gray-600 text-lg">Don't just take our word for it</p>
    </div>

    <% if @testimonials.any? %>
      <!-- Testimonials Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @testimonials.each do |testimonial| %>
          <div class="bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300">
            <!-- Author Info -->
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 rounded-full overflow-hidden bg-[#A53F2B]/10">
                <% if testimonial.avatar.attached? %>
                  <%= image_tag testimonial.avatar.variant(resize_to_limit: [100, 100]), 
                      loading: "lazy", 
                      alt: testimonial.author_name,
                      class: "w-full h-full object-cover" %>
                <% else %>
                  <div class="w-full h-full bg-gradient-to-br from-[#A53F2B] to-[#FFB347] flex items-center justify-center">
                    <span class="text-white text-lg font-bold"><%= testimonial.author_name[0] %></span>
                  </div>
                <% end %>
              </div>
              <div>
                <h4 class="font-bold text-gray-900"><%= testimonial.author_name %></h4>
                <% if testimonial.author_title.present? %>
                  <p class="text-sm text-gray-500"><%= testimonial.author_title %></p>
                <% end %>
              </div>
            </div>

            <!-- Testimonial Content -->
            <p class="text-gray-600 mb-4 italic">"<%= testimonial.content %>"</p>

            <!-- Star Rating -->
            <div class="flex items-center gap-1">
              <% testimonial.star_rating.to_i.times do %>
                <svg class="w-5 h-5 text-[#FFB347]" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              <% end %>
              <% (5 - testimonial.star_rating.to_i).times do %>
                <svg class="w-5 h-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- View All Link -->
      <div class="text-center mt-12">
        <%= link_to testimonials_path, 
            class: "inline-flex items-center gap-2 text-[#A53F2B] font-semibold hover:text-[#8A351F] transition-colors duration-300 group" do %>
          <span>Read More Stories</span>
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        <% end %>
      </div>

    <% else %>
      <!-- Empty State -->
      <div class="text-center py-16 bg-white rounded-2xl">
        <div class="w-20 h-20 bg-[#A53F2B]/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-10 h-10 text-[#A53F2B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
          </svg>
        </div>
        <p class="text-gray-600 mb-4">No testimonials yet</p>
        <%= link_to "Add Testimonial", new_testimonial_path, 
            class: "inline-flex items-center gap-2 bg-[#A53F2B] text-white px-6 py-3 rounded-lg hover:bg-[#8A351F] transition-colors duration-300 font-medium" %>
      </div>
    <% end %>
  </div>
</section>

<!-- CTA Section -->
<section class="py-20 bg-gradient-to-r from-[#A53F2B] to-[#8A351F] text-white">
  <div class="container mx-auto px-4 text-center">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
      <span class="block">Ready for Your Next Adventure?</span>
    </h2>

    <p class="text-xl md:text-2xl mb-10 text-white/90 max-w-2xl mx-auto">
      Join thousands of happy travelers who've explored with us
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <%= link_to new_booking_path, 
          class: "group bg-[#FFB347] text-[#2D2418] px-8 py-4 rounded-lg font-semibold text-lg hover:bg-[#E3B23C] transition-all duration-300 transform hover:scale-105 shadow-xl hover:shadow-2xl inline-flex items-center justify-center gap-2" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        <span>Book Now</span>
      <% end %>
      
      <%= link_to pages_contact_path, 
          class: "group bg-transparent text-white px-8 py-4 rounded-lg font-semibold text-lg border-2 border-white/50 hover:border-white hover:bg-white/10 transition-all duration-300 transform hover:scale-105 inline-flex items-center justify-center gap-2" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        <span>Contact Us</span>
      <% end %>
    </div>
  </div>
</section>

<!-- Partners Section -->
<%= render 'home/partners' %>