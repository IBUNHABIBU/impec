<footer class="bg-[#2D2418] text-white pt-16 pb-8">
  <div class="container mx-auto px-4">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8 mb-12">
      
      <!-- Company Info -->
      <div class="space-y-6">
        <!-- Logo or Brand -->
        <div class="flex items-center gap-2">
          <div class="w-10 h-10 bg-[#FFB347] rounded-lg flex items-center justify-center">
            <span class="text-[#2D2418] font-bold text-xl">IAT</span>
          </div>
          <span class="text-xl font-bold text-white">Impeccable Africa</span>
        </div>
        
        <p class="text-gray-300 leading-relaxed text-sm">
          Creating unforgettable travel experiences since 2010. Our expert guides will show you the world's hidden treasures.
        </p>
        
        <!-- Social Links -->
        <div class="flex items-center gap-3">
          <a href="#" class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center hover:bg-[#FFB347] transition-colors duration-300 group" aria-label="Facebook">
            <span class="sr-only">Facebook</span>
            <svg class="w-5 h-5 text-gray-300 group-hover:text-[#2D2418] transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
            </svg>
          </a>
          
          <a href="#" class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center hover:bg-[#FFB347] transition-colors duration-300 group" aria-label="Instagram">
            <span class="sr-only">Instagram</span>
            <svg class="w-5 h-5 text-gray-300 group-hover:text-[#2D2418] transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
            </svg>
          </a>
          
          <a href="#" class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center hover:bg-[#FFB347] transition-colors duration-300 group" aria-label="Twitter">
            <span class="sr-only">Twitter</span>
            <svg class="w-5 h-5 text-gray-300 group-hover:text-[#2D2418] transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-bold text-white mb-4 relative inline-block">
          Quick Links
          <span class="absolute -bottom-1 left-0 w-12 h-0.5 bg-[#FFB347] rounded-full"></span>
        </h3>
        
        <ul class="space-y-3">
          <li>
            <%= link_to root_path, class: "text-gray-300 hover:text-[#FFB347] transition-colors duration-300 flex items-center gap-2 group" do %>
              <span class="w-1 h-1 bg-[#FFB347] rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
              <span>Home</span>
            <% end %>
          </li>
          <li>
            <%= link_to travel_tours_path, class: "text-gray-300 hover:text-[#FFB347] transition-colors duration-300 flex items-center gap-2 group" do %>
              <span class="w-1 h-1 bg-[#FFB347] rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
              <span>Tours</span>
            <% end %>
          </li>
          <li>
            <%= link_to destinations_path, class: "text-gray-300 hover:text-[#FFB347] transition-colors duration-300 flex items-center gap-2 group" do %>
              <span class="w-1 h-1 bg-[#FFB347] rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
              <span>Destinations</span>
            <% end %>
          </li>
          <li>
            <%= link_to pages_about_path, class: "text-gray-300 hover:text-[#FFB347] transition-colors duration-300 flex items-center gap-2 group" do %>
              <span class="w-1 h-1 bg-[#FFB347] rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
              <span>About Us</span>
            <% end %>
          </li>
          <li>
            <%= link_to pages_contact_path, class: "text-gray-300 hover:text-[#FFB347] transition-colors duration-300 flex items-center gap-2 group" do %>
              <span class="w-1 h-1 bg-[#FFB347] rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
              <span>Contact</span>
            <% end %>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-lg font-bold text-white mb-4 relative inline-block">
          Contact Us
          <span class="absolute -bottom-1 left-0 w-12 h-0.5 bg-[#FFB347] rounded-full"></span>
        </h3>
        
        <ul class="space-y-4">
          <li class="flex items-start gap-3 text-gray-300">
            <svg class="w-5 h-5 text-[#FFB347] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span class="text-sm hover:text-white transition-colors">impecable@gmail.com</span>
          </li>
          
          <li class="flex items-start gap-3 text-gray-300">
            <svg class="w-5 h-5 text-[#FFB347] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="text-sm hover:text-white transition-colors">+255688744482</span>
          </li>
          
          <li class="flex items-start gap-3 text-gray-300">
            <svg class="w-5 h-5 text-[#FFB347] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm leading-relaxed">
              P.O.Box 10864, Ferry maji street<br />
              Kigamboni District,<br />
              Dar es salaam, Tanzania
            </span>
          </li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="text-lg font-bold text-white mb-4 relative inline-block">
          Newsletter
          <span class="absolute -bottom-1 left-0 w-12 h-0.5 bg-[#FFB347] rounded-full"></span>
        </h3>
        
        <p class="text-gray-300 text-sm mb-4">Subscribe for travel tips and exclusive deals</p>
        
        <form class="space-y-3">
          <label for="email" class="sr-only">Email address</label>
          <input 
            id="email" 
            name="email" 
            type="email" 
            autocomplete="email" 
            required 
            placeholder="Your email"
            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#FFB347] focus:border-transparent transition-all duration-300 text-sm"
          >
          
          <button 
            type="submit" 
            class="w-full bg-[#FFB347] text-[#2D2418] px-4 py-3 rounded-lg font-semibold text-sm hover:bg-[#E3B23C] transition-all duration-300 transform hover:scale-105 flex items-center justify-center gap-2 group"
          >
            <span>Subscribe</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </form>
        
        <!-- Trust Badge -->
        <p class="text-xs text-gray-400 mt-4">
          ✦ No spam, unsubscribe anytime
        </p>
      </div>
    </div>

    <!-- Bottom Bar with Copyright -->
    <div class="pt-8 mt-8 border-t border-white/10">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-400 text-sm text-center md:text-left">
          &copy; <%= Time.current.year %> Impeccable Africa Tours. All rights reserved.
        </p>
        
        <div class="flex items-center gap-6">
          <%= link_to "Privacy Policy", root_path, class: "text-gray-400 hover:text-[#FFB347] transition-colors duration-300 text-sm" %>
          <%= link_to "Terms of Service", root_path, class: "text-gray-400 hover:text-[#FFB347] transition-colors duration-300 text-sm" %>
          <%= link_to "Cookie Policy", root_path, class: "text-gray-400 hover:text-[#FFB347] transition-colors duration-300 text-sm" %>
        </div>
        
        <!-- Payment Methods Icons (Optional) -->
        <div class="flex items-center gap-2">
          <span class="text-xs text-gray-500">We Accept:</span>
          <div class="flex items-center gap-1">
            <div class="w-8 h-5 bg-white/10 rounded text-[8px] flex items-center justify-center text-gray-400">Visa</div>
            <div class="w-8 h-5 bg-white/10 rounded text-[8px] flex items-center justify-center text-gray-400">MC</div>
            <div class="w-8 h-5 bg-white/10 rounded text-[8px] flex items-center justify-center text-gray-400">Amex</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>