<div class="min-h-screen bg-stone-50 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Flash Notice -->
  
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8">
      <h1 class="text-3xl font-extrabold text-stone-900 sm:text-4xl mb-4 sm:mb-0">Testimonial Details</h1>
    </div>

    <!-- Testimonial Card -->
    <div class="mb-8">
      <%= render 'testimonials/testimonialcard' %>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 pt-6 border-t border-stone-200">
      <%= link_to "Back to testimonials", testimonials_path, 
          class: "inline-flex items-center px-4 py-2 border border-stone-300 text-sm font-medium rounded-md text-stone-700 bg-white hover:bg-stone-50 transition-colors duration-200" %>
      
      <% if admin_user? %>
        <%= link_to "Edit this testimonial", edit_testimonial_path(@testimonial), 
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-orange-600 hover:bg-orange-700 transition-colors duration-200" %>
        
        <%= button_to "Delete this testimonial", @testimonial, 
            method: :delete, 
            data: { turbo_confirm: "Are you sure?" },
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 transition-colors duration-200" %>
      <% end %>
    </div>
  </div>
</div>
