<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-extrabold text-gray-900 text-center mb-12">
      Meet Our Guides
    </h2>
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <% @team_members.each do |member| %>
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
          <% if member.photo.attached? %>
            <%= image_tag url_for(member.photo.variant(resize_to_limit: [100, 100]),
              loading: "lazy"), class: "w-full h-64 object-cover", alt: member.name %>
          <% else %>
            <%= image_tag "mavelogo.png", class: "w-full h-64 object-cover", alt: member.name %>
          <% end %>
          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-900"><%= member.name %></h3>
            <p class="text-amber-600"><%= member.title %></p>
            <p class="mt-2 text-gray-600"><%= member.bio %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="py-16 bg-amber-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
