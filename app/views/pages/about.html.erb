<!-- app/views/pages/about.html.erb -->

<!-- Hero Section -->
<section class="relative bg-gradient-to-b from-amber-50 to-white pt-16 pb-20">
  <div class="container mx-auto px-4">
    <div class="space-y-6 text-center">
      
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
        <span class="text-[#A53F2B]">Our Story</span>
      </h1>

      <%= render "pages/ourstory" %>

    </div>
  </div>
</section>

<!-- Vision Section -->
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1 space-y-6">
        <div class="relative">
          <div class="absolute -left-4 top-0 w-12 h-12 bg-[#FFB347]/30 rounded-full"></div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 relative pl-4">
            Our <span class="text-[#A53F2B]">Vision</span>
          </h2>
        </div>

        <p class="text-lg text-gray-600 leading-relaxed">
          To dismantle barriers in the travel industry by providing inclusive,
          high-quality African adventures that empower the Deaf community and celebrate diversity.
        </p>
        
        <div class="flex items-center gap-2 pt-4">
          <div class="w-2 h-2 bg-[#FFB347] rounded-full"></div>
          <div class="w-2 h-2 bg-[#FFB347]/60 rounded-full"></div>
          <div class="w-2 h-2 bg-[#FFB347]/30 rounded-full"></div>
        </div>
      </div>

      <div class="order-1 lg:order-2 relative">
        <div class="absolute inset-0 bg-gradient-to-tr from-[#A53F2B]/20 to-transparent rounded-2xl"></div>
        <%= image_tag "tembo.jpg", alt: "Inspiring travel vision", class: "rounded-2xl shadow-lg w-full h-[400px] object-cover" %>
      </div>
    </div>
  </div>
</section>

<!-- Mission Section -->
<section class="py-16 bg-amber-50">
  <div class="container mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-tl from-[#A53F2B]/20 to-transparent rounded-2xl"></div>
        <%= image_tag "twigasingle.jpg", alt: "Our mission in action", class: "rounded-2xl shadow-lg w-full h-[400px] object-cover" %>
      </div>

      <div class="space-y-6">
        <div class="relative">
          <div class="absolute -left-4 top-0 w-12 h-12 bg-[#FFB347]/30 rounded-full"></div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 relative pl-4">
            Our <span class="text-[#A53F2B]">Mission</span>
          </h2>
        </div>

        <p class="text-lg text-gray-600 leading-relaxed">
          To be the global leader in inclusive tourism, where every traveler,
          regardless of ability, can experience the untamed beauty of Africa with dignity and joy.
        </p>
        
        <div class="grid grid-cols-3 gap-4 pt-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-[#A53F2B]">100%</div>
            <div class="text-sm text-gray-500">Inclusive</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-[#A53F2B]">15+</div>
            <div class="text-sm text-gray-500">Years</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-[#A53F2B]">1000+</div>
            <div class="text-sm text-gray-500">Travelers</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Why We Exist Section -->
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center mb-12">
      <div class="relative inline-block">
        <div class="absolute -left-6 -top-6 w-12 h-12 bg-[#FFB347]/20 rounded-full"></div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 relative">
          Why <span class="text-[#A53F2B]">We Exist</span>
        </h2>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Specialized Expertise -->
      <div class="bg-amber-50 p-6 rounded-xl hover:shadow-lg transition-shadow duration-300">
        <div class="w-12 h-12 bg-[#A53F2B] rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Specialized Expertise</h3>
        <p class="text-gray-600">We are pioneers in inclusive tourism, offering professional Sign Language interpreters and specialized guides who understand the unique needs of Deaf travelers.</p>
      </div>

      <!-- Total Peace of Mind -->
      <div class="bg-amber-50 p-6 rounded-xl hover:shadow-lg transition-shadow duration-300">
        <div class="w-12 h-12 bg-[#FFB347] rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-[#2D2418]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Total Peace of Mind</h3>
        <p class="text-gray-600">From airport transfers to accommodations and events, we manage everything.</p>
      </div>

      <!-- Authentic Cultural Connection -->
      <div class="bg-amber-50 p-6 rounded-xl hover:shadow-lg transition-shadow duration-300">
        <div class="w-12 h-12 bg-[#A53F2B] rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Authentic Cultural Connection</h3>
        <p class="text-gray-600">We provide insights into African wildlife, traditions, and Deaf heritage.</p>
      </div>

      <!-- Tailored Experiences -->
      <div class="bg-amber-50 p-6 rounded-xl hover:shadow-lg transition-shadow duration-300">
        <div class="w-12 h-12 bg-[#FFB347] rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-[#2D2418]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Tailored Experiences</h3>
        <p class="text-gray-600">From luxury safaris to budget adventures, we design travel experiences that match your dreams.</p>
      </div>
    </div>
  </div>
</section>

<!-- Journey Timeline Section -->
<section class="py-16 bg-amber-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
        Our <span class="text-[#A53F2B]">Journey</span>
      </h2>
    </div>

    <div class="max-w-3xl mx-auto">
      <!-- Timeline Item -->
      <div class="relative flex items-start gap-6 pb-12">
        <!-- Timeline line -->
        <div class="absolute left-[23px] top-12 bottom-0 w-0.5 bg-[#FFB347]/30"></div>
        
        <!-- Year bubble -->
        <div class="relative z-10">
          <div class="w-12 h-12 bg-[#A53F2B] rounded-full flex items-center justify-center text-white font-bold">
            2010
          </div>
        </div>

        <!-- Content -->
        <div class="flex-1 bg-white p-6 rounded-xl shadow-md">
          <h3 class="text-xl font-bold text-gray-900 mb-2">The Spirit of Lorraine D’Arcy</h3>
          <p class="text-gray-600">
            IAT was born from the meeting of three visionary minds: Lorraine D’Arcy, an Australian 
            trailblazer, and Tanzanian leaders Habib Mrope and Joseph Hiza. Together, they recognized
             that travel has a unique power to ignite the spirit and enrich the soul.Through a global 
             network of trusted branches and world-class tourism brands, we have built a specialized 
             sanctuary for inclusive travel. While our heart lies in empowering the Deaf community, 
             our doors are open to everyone—non-disabled travelers and people with all types of disabilities 
             alike. From the moment you land until your final
             farewell, we handle every detail,
             ensuring your journey is seamless, soulful, and truly 
            impeccable.
          </p>
        </div>
      </div>

      <!-- Add more timeline items as needed -->
    </div>
  </div>
</section>

<!-- Team Section -->
<section class="py-16 bg-white" id="team">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
        Meet Our <span class="text-[#A53F2B]">Guides</span>
      </h2>
      <p class="text-gray-600 mt-4 max-w-2xl mx-auto">Passionate experts dedicated to making your African adventure unforgettable</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @team_members.each do |member| %>
        <div class="group bg-amber-50 rounded-xl overflow-hidden hover:shadow-xl transition-shadow duration-300">
          <div class="relative h-64 overflow-hidden">
            <% if member.photo.attached? %>
              <%= image_tag url_for(member.photo.variant(resize_to_limit: [400, 400]), loading: "lazy"), 
                  class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-500",
                  alt: member.name %>
            <% else %>
              <div class="w-full h-full bg-gradient-to-br from-[#A53F2B] to-[#FFB347] flex items-center justify-center">
                <span class="text-6xl text-white/50"><%= member.name[0] %></span>
              </div>
            <% end %>
          </div>

          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-900 mb-1"><%= member.name %></h3>
            <p class="text-[#A53F2B] font-medium mb-3"><%= member.title %></p>
            <p class="text-gray-600 text-sm leading-relaxed"><%= member.bio %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Core Values Section -->
<section class="py-16 bg-amber-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
        Our Core <span class="text-[#A53F2B]">Values</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <% @values.each do |value| %>
        <div class="bg-white p-6 rounded-xl text-center hover:shadow-lg transition-shadow duration-300">
          <div class="w-16 h-16 bg-[#A53F2B]/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <div class="text-[#A53F2B] text-2xl">
              <%= value_icon(value[:icon]) %>
            </div>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2"><%= value[:title] %></h3>
          <p class="text-gray-600 text-sm"><%= value[:description] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Responsible Tourism Section -->
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
          Responsible <span class="text-[#A53F2B]">Tourism</span>
        </h2>

        <p class="text-lg text-gray-600 leading-relaxed">
          At IAT, we believe that true travel leaves a positive footprint.
          A portion of our efforts supports local organizations and projects that uplift communities
          and empower marginalized groups.
        </p>

        <%= link_to root_path, 
            class: "inline-flex items-center gap-2 bg-[#A53F2B] text-white px-6 py-3 rounded-lg hover:bg-[#8A351F] transition-colors duration-300 font-medium" do %>
          Learn more
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        <% end %>
      </div>

      <div class="relative">
        <div class="absolute -inset-4 bg-[#FFB347]/10 rounded-2xl"></div>
        <%= image_tag "comunity.jpg", alt: "Conservation project", class: "relative rounded-2xl shadow-xl w-full h-[400px] object-cover" %>
      </div>
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="py-20 bg-gradient-to-r from-[#A53F2B] to-[#8A351F] text-white">
  <div class="container mx-auto px-4 text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to Explore With Us?</h2>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <%= link_to "#team", 
          class: "bg-white text-[#A53F2B] px-8 py-3 rounded-lg font-medium hover:bg-amber-50 transition-colors duration-300 inline-flex items-center justify-center gap-2" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
        </svg>
        Meet Our Guides
      <% end %>
      
      <%= link_to travel_tours_path, 
          class: "bg-[#FFB347] text-[#2D2418] px-8 py-3 rounded-lg font-medium hover:bg-[#E3B23C] transition-colors duration-300 inline-flex items-center justify-center gap-2" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
        </svg>
        View Tours
      <% end %>
    </div>
  </div>
</section>