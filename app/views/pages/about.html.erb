            <%= value_icon(value[:icon], class: "h-8 w-8 text-#{value[:color]}-600") %>
          </div>
          <h3 class="text-lg font-medium text-gray-900"><%= value[:title] %></h3>
          <p class="mt-2 text-gray-600"><%= value[:description] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

