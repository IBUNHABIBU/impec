<!-- Our Story Section with Lorraine's Legacy -->
<section class="relative py-20 bg-gradient-to-b from-white to-amber-50 overflow-hidden">
  <!-- Decorative Elements -->
  <div class="absolute top-0 left-0 w-64 h-64 bg-[#FFB347]/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-[#A53F2B]/5 rounded-full translate-x-1/3 translate-y-1/3"></div>
  
  <div class="container mx-auto px-4 relative">
    <!-- Header with Legacy Title -->
    <div class="max-w-4xl mx-auto text-center mb-16">
      <div class="inline-block mb-4">
        <span class="bg-[#A53F2B]/10 text-[#A53F2B] px-4 py-2 rounded-full text-sm font-medium tracking-wider uppercase">
          A Legacy in Motion
        </span>
      </div>
      
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight">
        Remembering <span class="text-[#A53F2B] relative">
          Lorraine D'Arcy
          <span class="absolute -bottom-2 left-0 w-full h-1 bg-[#FFB347]/30 rounded-full"></span>
        </span>
      </h1>
      
      <p class="text-xl text-gray-600 italic max-w-3xl mx-auto">
        "In the heart of every great journey lies a story of passion..."
      </p>
    </div>

    <!-- Main Content Grid -->
    <div class="max-w-4xl mx-auto">
      <!-- Introduction Card with Portrait -->
      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div class="md:col-span-1">
          <div class="relative group">
            <!-- IMAGE 1: Lorraine Portrait -->
            <div class="absolute -inset-2 bg-gradient-to-r from-[#FFB347] to-[#A53F2B] rounded-2xl opacity-75 group-hover:opacity-100 transition-opacity duration-300 blur-sm"></div>
            <div class="relative">
              <%= image_tag "lorain.jpg", alt: "Lorraine D'Arcy - Founder of Impeccable Africa Tours", 
                  class: "w-full h-auto object-cover rounded-xl shadow-lg border-4 border-white",
                  onerror: "this.onerror=null; this.src='https://via.placeholder.com/400x500?text=Lorraine+D%27Arcy'" %>
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-[#A53F2B] to-transparent p-4 rounded-b-xl">
                <p class="text-white font-semibold text-lg">Lorraine D'Arcy</p>
                <p class="text-white/80 text-sm">Founder & Visionary</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="md:col-span-2 bg-white rounded-2xl shadow-xl p-8 md:p-10 relative border-l-4 border-[#FFB347] flex items-center">
          <div class="absolute -top-3 -right-3 w-16 h-16 bg-[#A53F2B] rounded-full flex items-center justify-center text-white text-2xl font-bold shadow-lg">
            IAT
          </div>
          <div>
            <p class="text-lg text-gray-700 leading-relaxed mb-4">
              <span class="font-bold text-[#A53F2B] text-xl">Impeccable Africa Tours (IAT)</span> stands as a testament to a world without barriers, 
              born from the meeting of three visionary souls—<span class="font-semibold text-[#A53F2B]">Lorraine</span>, an Australian powerhouse, 
              and Tanzanian leaders <span class="font-semibold text-[#A53F2B]">Habib Mrope</span> and <span class="font-semibold text-[#A53F2B]">Joseph Hiza</span>.
            </p>
            <div class="flex items-center gap-2 mt-4">
              <div class="w-2 h-2 bg-[#FFB347] rounded-full"></div>
              <div class="w-2 h-2 bg-[#FFB347]/60 rounded-full"></div>
              <div class="w-2 h-2 bg-[#FFB347]/30 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- A Life of Grace Section -->
      <div class="bg-white rounded-2xl shadow-lg p-8 mb-8 hover:shadow-xl transition-shadow duration-300">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-[#FFB347] rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-[#2D2418]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">A Life of <span class="text-[#A53F2B]">Grace and Leadership</span></h2>
        </div>
        
        <div class="grid md:grid-cols-4 gap-6">
          <div class="md:col-span-3">
            <p class="text-gray-700 leading-relaxed mb-4">
              Lorraine was far more than a traveler; she was a <span class="font-semibold text-[#A53F2B]">trailblazer</span>. A former winner of the Australian Deaf Modeling Competition, she carried that same elegance into her decades of advocacy.
            </p>
            
            <p class="text-gray-700 leading-relaxed">
              Until the age of 70, Lorraine served as a pillar for the Deaf and Deafblind communities, both as a devoted leader and a respected Sign Language teacher. Her global influence reached its peak during her tenure as Secretary General of <span class="font-semibold text-[#A53F2B]">Miss & Mister Deaf International</span>, where she mentored contestants with a maternal warmth that many will never forget.
            </p>
          </div>
          
          <div class="md:col-span-1 bg-[#A53F2B] rounded-xl p-4 text-white flex flex-col items-center justify-center text-center">
            <div class="text-4xl font-bold mb-1">70</div>
            <p class="text-sm">Years of<br>Advocacy</p>
            <div class="w-8 h-1 bg-[#FFB347] rounded-full my-2"></div>
            <p class="text-xs text-white/80 italic">Devoted leader</p>
          </div>
        </div>
      </div>

      <!-- The Spark Section -->
      <div class="bg-amber-50 rounded-2xl shadow-lg p-8 mb-8 relative overflow-hidden group hover:shadow-xl transition-all duration-300">
        <div class="absolute top-0 right-0 w-32 h-32 bg-[#FFB347]/10 rounded-full -translate-y-1/2 translate-x-1/2 group-hover:scale-150 transition-transform duration-500"></div>
        
        <div class="relative">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-[#A53F2B] rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">The <span class="text-[#A53F2B]">Spark</span>: From Iringa to a Global Vision</h2>
          </div>
          
          <p class="text-gray-700 leading-relaxed mb-4">
            The seeds of Impeccable Africa Tours were sown during Lorraine's tireless research into inclusive tourism. A pivotal visit to <span class="font-semibold text-[#A53F2B]">Neema Crafts in Iringa</span>—a center renowned for empowering people with disabilities—deeply moved her.
          </p>
          
          <div class="grid md:grid-cols-2 gap-6 mt-6">
            <div class="bg-white p-6 rounded-xl border-l-4 border-[#FFB347]">
              <p class="text-gray-700 italic">
                "Witnessing the profound impact of vocational training and community support, Lorraine realized that the beauty of Africa should be accessible to everyone."
              </p>
            </div>
            
            <div class="bg-white p-6 rounded-xl border-l-4 border-[#A53F2B]">
              <p class="text-gray-700">
                This experience became the <span class="font-semibold text-[#A53F2B]">"North Star"</span> for creating IAT, an organization dedicated to providing seamless, soulful travel experiences for the Deaf community.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- A Heart for Tanzania -->
      <div class="bg-white rounded-2xl shadow-lg p-8 mb-8">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-[#FFB347] rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-[#2D2418]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">A Heart for <span class="text-[#A53F2B]">Tanzania</span></h2>
        </div>
        
        <p class="text-gray-700 leading-relaxed mb-6">
          Lorraine's love for Tanzania was boundless. Whether she was exploring the historic ruins of <span class="font-semibold">Bagamoyo</span>, the vibrant streets of <span class="font-semibold">Zanzibar</span>, or the wild plains of <span class="font-semibold">Arusha</span>, she did so with a genuine smile that transcended language. She had a particular fondness for Africa's wildlife—from the playful monkeys to the majestic lions—and a deep respect for the continent's cultural heritage.
        </p>
        
        <div class="grid md:grid-cols-2 gap-6">
          <div class="space-y-3">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-[#FFB347] rounded-full"></div>
              <span class="text-gray-600">Historic ruins of Bagamoyo</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-[#FFB347] rounded-full"></div>
              <span class="text-gray-600">Vibrant streets of Zanzibar</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-[#FFB347] rounded-full"></div>
              <span class="text-gray-600">Wild plains of Arusha</span>
            </div>
          </div>
          
          <div class="bg-amber-50 p-4 rounded-xl">
            <p class="text-gray-700 italic">
              Her most cherished moments, however, were spent with children in Deaf schools, sharing Sign Language and gifts of sweets, balls, and school supplies.
            </p>
          </div>
        </div>
      </div>

      <!-- IMAGE 2: Lorraine with Children - Full Width -->
      <div class="relative group mb-8 h-80 rounded-2xl overflow-hidden shadow-xl">
        <div class="absolute inset-0 bg-gradient-to-r from-[#A53F2B]/70 to-[#FFB347]/70 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10 flex items-center justify-center">
          <p class="text-white text-xl font-bold text-center px-6">
            "Travel was not just about seeing new places;<br>it was about uplifting the people within them."
          </p>
        </div>
        <%= image_tag "shule.jpeg", alt: "Lorraine with children at Deaf school in Tanzania", 
            class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-700",
            onerror: "this.onerror=null; this.src='https://via.placeholder.com/1200x400?text=Lorraine+with+Children'" %>
        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-6 z-20">
          <p class="text-white text-lg font-semibold">Lorraine and Habib Mrope with children at a Deaf school in Tanzania</p>
          <p class="text-white/80 text-sm">Sharing language, love, and laughter</p>
        </div>
      </div>

      <!-- Carrying the Torch Section -->
      <div class="grid md:grid-cols-3 gap-8 mb-8">
        <div class="md:col-span-2 bg-white rounded-2xl shadow-lg p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-[#FFB347] rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-[#2D2418]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">Carrying the <span class="text-[#A53F2B]">Torch</span></h2>
          </div>
          
          <p class="text-gray-700 leading-relaxed mb-4">
            Though Lorraine is no longer with us, her mission lives on through <span class="font-semibold text-[#A53F2B]">Habib Mrope</span> and <span class="font-semibold text-[#A53F2B]">Joseph Hiza</span>. In 2021, she saw her dream come full circle when <span class="font-semibold text-[#A53F2B]">Tanzania hosted the Miss & Mister Deaf International competition</span>—a moment of immense pride for her and a milestone for the continent.
          </p>
          
          <div class="mt-6 p-5 bg-gradient-to-r from-amber-50 to-white rounded-xl border border-[#FFB347]/30">
            <p class="text-gray-800 text-lg font-medium">
              <span class="text-[#A53F2B] text-2xl">"</span> At Impeccable Africa Tours, we don't just offer safaris; we offer the world through Lorraine's eyes—full of wonder, inclusivity, and an unwavering belief in human connection.
            </p>
          </div>
        </div>

        <div class="bg-[#FFB347] rounded-2xl shadow-lg p-6 text-[#2D2418] flex flex-col justify-center items-center text-center">
          <div class="text-5xl font-bold mb-2">2021</div>
          <p class="text-xl mb-2">Tanzania Hosts</p>
          <p class="font-semibold text-lg">Miss & Mister Deaf International</p>
          <div class="w-12 h-1 bg-[#A53F2B] rounded-full my-3"></div>
          <p class="text-sm opacity-80">A milestone for the continent</p>
        </div>
      </div>

      <!-- Legacy Call to Action -->
      <div class="text-center bg-white rounded-2xl shadow-xl p-10 border-2 border-[#FFB347]/20">
        <h3 class="text-3xl font-bold text-gray-900 mb-4">
          We invite you to join us on a journey that honors her 
          <span class="text-[#A53F2B]">remarkable legacy</span>
        </h3>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
          <a href="#tours" class="inline-flex items-center justify-center gap-2 bg-[#A53F2B] text-white px-8 py-3 rounded-lg hover:bg-[#8A351F] transition-colors duration-300 font-medium shadow-lg hover:shadow-xl">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
            </svg>
            Explore Tours
          </a>
          <a href="#contact" class="inline-flex items-center justify-center gap-2 bg-[#FFB347] text-[#2D2418] px-8 py-3 rounded-lg hover:bg-[#E3B23C] transition-colors duration-300 font-medium shadow-lg hover:shadow-xl">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </div>
</section>