<% if resource.errors.any? %>
  <div id="error_explanation" 
       data-turbo-cache="false"
       class="bg-red-50 border-l-4 border-[#A53F2B] rounded-lg p-6 mb-8 shadow-lg animate-fade-in">
    
    <!-- Header with Icon -->
    <div class="flex items-center gap-3 mb-4">
      <div class="flex-shrink-0">
        <svg class="h-6 w-6 text-[#A53F2B]" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
      </div>
      <h2 class="text-lg font-bold text-[#2D2418]">
        <%= I18n.t("errors.messages.not_saved",
                   count: resource.errors.count,
                   resource: resource.class.model_name.human.downcase) %>
      </h2>
    </div>
    
    <!-- Error List -->
    <ul class="space-y-2 ml-9">
      <% resource.errors.full_messages.each do |message| %>
        <li class="flex items-start gap-2 text-sm text-[#2D2418]">
          <span class="flex-shrink-0 w-1.5 h-1.5 rounded-full bg-[#A53F2B] mt-1.5"></span>
          <span><%= message %></span>
        </li>
      <% end %>
    </ul>
    
    <!-- Optional: Dismiss button -->
    <div class="mt-4 flex justify-end">
      <button type="button"
              onclick="this.closest('#error_explanation').remove()"
              class="text-xs text-gray-500 hover:text-[#A53F2B] transition-colors duration-300 flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
        <span>Dismiss</span>
      </button>
    </div>
  </div>
<% end %>
